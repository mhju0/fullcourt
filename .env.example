# Required by server routes and data-pipeline scripts.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Optional: enables Supabase Realtime score updates in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Required for the Vercel cron endpoint in production.
CRON_SECRET=REPLACE_WITH_A_RANDOM_SECRET

# Optional Postgres pool limit (defaults to 1 on Vercel and 5 elsewhere).
DB_POOL_MAX=5

# Optional ingest/backfill tuning.
NBA_SEED_SKIP_OT=false
NBA_API_DELAY_SECONDS=1.0
