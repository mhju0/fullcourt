# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env*.local
scripts/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
venv/
scripts/venv/
ml/.venv/
__pycache__/
scripts/__pycache__/
ml/__pycache__/

# ml artifacts (large binaries / data — keep out of git)
ml/data/
ml/shot_value/*.pkl

# playwright
/playwright-report/
/test-results/

# local caches
.pnpm-store/
.serena/

# agent / local project memory
# CLAUDE.md is local-only project memory (may contain machine-specific notes) — keep private
CLAUDE.md

# Claude Code: publish OUR workflow assets, keep local + third-party out
.claude/settings.local.json
.claude/skills/react-best-practices/